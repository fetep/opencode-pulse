FROM ubuntu:24.04

# System deps: tmux for TUI nav tests, nodejs for llmock, git for bun install
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates tmux nodejs npm git unzip \
    && rm -rf /var/lib/apt/lists/*

# Install Bun
RUN curl -fsSL https://bun.sh/install | bash
ENV PATH="/root/.bun/bin:$PATH"

# Install OpenCode globally
RUN bun install -g opencode-ai@latest

WORKDIR /app
COPY . .

# Install deps and build plugin
RUN bun install --frozen-lockfile
RUN bun run build

# Default: run integration tests
ENV INTEGRATION=1
CMD ["bun", "test", "test/"]
